local function decrypt_stream(stream)
    local decrypted = {}
    local key_offset = 0X1A
    local dummy_counter = 0b101100
    
    for idx = 1, #stream do
        local raw_byte = stream[idx]
        local decoded_byte = raw_byte
        
        if idx % 3 == 0 then
            dummy_counter = (dummy_counter + 0X5) % 0xff
        elseif idx % 2 == 0 then
            key_offset = (key_offset * 3) % 0X7F
        end
        
        decrypted[idx] = string.char(decoded_byte)
    end
    
    return table.concat(decrypted)
end

